# Author: Rámon van Raaij | Bluesky: @ramonvanraaij.nl | GitHub: https://github.com/ramonvanraaij | Website: https://ramon.vanraaij.eu
#
# Installed as /usr/lib/systemd/system-sleep/tas2781-firmware-resume
# by run_once_setup-tas2781-firmware-reload.sh.tmpl.
#
# The TAS2781 smart amplifiers lose their register state during system
# suspend. This hook re-initialises the amplifiers via I2C after every
# resume (s2idle, S3, hibernate) by calling 2pa-byps.sh, which directly
# programs the chip registers without touching the kernel driver binding.
# This is safe to run while PipeWire / WirePlumber are resuming.
# =================================================================

# errexit intentionally omitted — sleep hooks must not abort mid-execution.
set -o nounset -o pipefail

# $1 = pre|post, $2 = suspend|hibernate|hybrid-sleep|suspend-then-hibernate
[[ "${1}" == "post" ]] || exit 0

# Allow the I2C controller and platform drivers to settle after resume
# before programming the amplifier registers.
sleep 3

/usr/local/bin/2pa-byps.sh | logger -t tas2781-resume
